<?xml version="1.0" encoding="utf-8"?>
<!--
  Sunset icon — sun sitting on the horizon line, half arc visible.
  Used for Row 2 of the widget.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Horizon line -->
    <path
        android:pathData="M3,17L21,17"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Sun arc (upper half only) -->
    <path
        android:pathData="M5.5,17A6.5,6.5 0,0 1,18.5 17"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />

    <!-- Centre ray upward -->
    <path
        android:pathData="M12,10L12,7.5"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Diagonal rays -->
    <path
        android:pathData="M6.8,11.8L5.1,10.1"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />
    <path
        android:pathData="M17.2,11.8L18.9,10.1"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />
</vector>
