<?xml version="1.0" encoding="utf-8"?>
<!-- CRITICAL: Only RemoteViews-compatible views allowed in widget layouts -->
<!-- Allowed: FrameLayout, LinearLayout, RelativeLayout, GridLayout,
     TextView, ImageView, Button, ImageButton, ProgressBar, Chronometer,
     AnalogClock, ViewFlipper, ListView, GridView, StackView, AdapterViewFlipper -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <!-- Dynamic background gradient view (ImageView with programmatic bitmap) -->
    <ImageView
        android:id="@+id/background_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <!-- Top bar: location toggle icon -->
    <ImageView
        android:id="@+id/btn_location_toggle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="4dp"
        android:src="@drawable/ic_location_gps"
        android:contentDescription="@string/toggle_location"
        android:tint="@android:color/white"
        android:padding="2dp" />

    <!-- Main content: horizontal split -->
    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- LEFT: Weather panel -->
        <LinearLayout
            android:id="@+id/weather_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="2dp">

            <!-- Weather icon + temperature row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_weather_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_weather_sunny"
                    android:contentDescription="@string/weather_icon_desc"
                    android:tint="@android:color/white" />

                <TextView
                    android:id="@+id/tv_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Weather description -->
            <TextView
                android:id="@+id/tv_weather_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Hi/Lo -->
            <TextView
                android:id="@+id/tv_hi_lo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="H:--  L:--"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:maxLines="1" />

            <!-- Precipitation -->
            <LinearLayout
                android:id="@+id/row_precip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_water_drop"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_precip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- Barometer -->
            <LinearLayout
                android:id="@+id/row_pressure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_pressure_arrow"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_arrow_up"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_pressure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--- hPa"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#66FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- RIGHT: Sun panel -->
        <LinearLayout
            android:id="@+id/sun_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="2dp"
            android:visibility="visible">

            <!-- Sunrise row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sunrise"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Sunset row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sunset"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Daylight duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_daylight"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_daylight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--h --m"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Solar noon (bonus) -->
            <TextView
                android:id="@+id/tv_solar_noon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:layout_marginTop="2dp"
                android:maxLines="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Last updated timestamp -->
    <TextView
        android:id="@+id/tv_last_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:text=""
        android:textColor="#99FFFFFF"
        android:textSize="8sp"
        android:layout_margin="3dp" />

</RelativeLayout>
