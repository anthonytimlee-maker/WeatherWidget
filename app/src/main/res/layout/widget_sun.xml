<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <!-- Gradient sky background -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <!-- Content overlay - horizontal split -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">

        <!-- LEFT: Weather section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Current temp (large) -->
            <TextView
                android:id="@+id/tv_temp_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24°"
                android:textSize="32sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <!-- High/Low -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_temp_high"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="27°"
                    android:textSize="12sp"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / "
                    android:textSize="12sp"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tv_temp_low"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18°"
                    android:textSize="12sp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Condition -->
            <TextView
                android:id="@+id/tv_weather_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunny"
                android:textSize="11sp"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/v_divider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="#33FFFFFF" />

        <!-- RIGHT: Solar section (existing) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Sunrise -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_icon_sunrise"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_sunrise"
                    android:contentDescription="@string/cd_sunrise" />

                <TextView
                    android:id="@+id/tv_sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/placeholder_time" />
            </LinearLayout>

            <!-- Sunset -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_icon_sunset"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_sunset"
                    android:contentDescription="@string/cd_sunset" />

                <TextView
                    android:id="@+id/tv_sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/placeholder_time" />
            </LinearLayout>

            <!-- Daylight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_icon_daylight"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="@string/cd_daylight" />

                <TextView
                    android:id="@+id/tv_daylight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/placeholder_duration" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
